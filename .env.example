# --- App ---
# Chiave per firmare i cookie di sessione. Genera con: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-me-please-32-bytes-hex

# Directory dati persistenti. Su Azure App Service usa /home/data (montato e persistente).
DATA_DIR=./data

# Durata sessione admin in secondi (default 8h)
SESSION_MAX_AGE=28800

# --- Google Analytics MCP (analytics-mcp) ---
# Percorso al file JSON delle credenziali del service account Google.
# Su Azure caricalo sotto /home e punta qui.
GOOGLE_APPLICATION_CREDENTIALS=/home/credentials.json
GOOGLE_PROJECT_ID=
